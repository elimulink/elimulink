rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------
    // Claims-based auth helpers
    // ---------------------------
    function isAuthenticated() {
      return request.auth != null;
    }

    function claimRole() {
      return isAuthenticated() ? request.auth.token.role : null;
    }

    function claimInstitutionId() {
      return isAuthenticated() ? request.auth.token.institutionId : null;
    }

    function claimDepartmentId() {
      return isAuthenticated() ? request.auth.token.departmentId : null;
    }

    function canonicalRole() {
      let role = claimRole();
      role = role == null ? 'public' : role;
      return role == 'superAdmin' ? 'super_admin'
        : role == 'institutionAdmin' ? 'institution_admin'
        : role == 'departmentAdmin' ? 'department_head'
        : role == 'staff' ? 'lecturer'
        : role == 'institution_student' ? 'student'
        : role == 'student_general' ? 'student'
        : role;
    }

    function isSuperAdmin() {
      return canonicalRole() == 'super_admin';
    }

    function isInstitutionAdmin() {
      return canonicalRole() == 'institution_admin';
    }

    function isDepartmentHead() {
      return canonicalRole() == 'department_head';
    }

    function isLecturer() {
      return canonicalRole() == 'lecturer';
    }

    function isStaff() {
      return isDepartmentHead() || isLecturer();
    }

    function isStudentRole() {
      return canonicalRole() == 'student';
    }

    function institutionMatch(institutionId) {
      return isSuperAdmin() || claimInstitutionId() == institutionId;
    }

    function departmentMatch(departmentId) {
      return isSuperAdmin()
        || isInstitutionAdmin()
        || claimDepartmentId() == departmentId;
    }

    function departmentOrGeneralMatch(departmentId) {
      return departmentId == 'general' || departmentMatch(departmentId);
    }

    // Lock privileged identity/tenant fields from client profile writes.
    function isSafeProfileCreate() {
      return !request.resource.data.keys().hasAny([
        'role', 'institutionId', 'departmentId', 'subscriptionActive',
        'staffCodeVerified', 'claims', 'customClaims', 'isAdmin'
      ]);
    }

    function isSafeProfileUpdate() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
        'role', 'institutionId', 'departmentId', 'subscriptionActive',
        'staffCodeVerified', 'claims', 'customClaims', 'isAdmin'
      ]);
    }

    function canReadInstitutionDepartment(institutionId, departmentId) {
      return isAuthenticated() && institutionMatch(institutionId) && departmentOrGeneralMatch(departmentId);
    }

    // ---------------------------
    // User profile + personal data
    // ---------------------------
    match /users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid && isSafeProfileCreate();
      allow update: if isAuthenticated() && request.auth.uid == uid && isSafeProfileUpdate();
      allow delete: if isSuperAdmin();
    }

    match /users/{uid}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // App-scoped profile path used by current frontend/backend.
    match /artifacts/{appId}/users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid && isSafeProfileCreate();
      allow update: if isAuthenticated() && request.auth.uid == uid && isSafeProfileUpdate();
      allow delete: if isSuperAdmin();
    }

    match /artifacts/{appId}/users/{uid}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ---------------------------
    // Institution root + datasets
    // ---------------------------
    match /institutions/{institutionId} {
      allow read: if isAuthenticated() && institutionMatch(institutionId);
      allow write: if isAuthenticated() && (isSuperAdmin() || (institutionMatch(institutionId) && isInstitutionAdmin()));
    }

    match /institutions/{institutionId}/students/{studentId} {
      allow read: if canReadInstitutionDepartment(institutionId, resource.data.departmentId)
        || (isAuthenticated() && institutionMatch(institutionId) && request.auth.uid == studentId);
      allow write: if isAuthenticated() && institutionMatch(institutionId) && (isInstitutionAdmin() || isStaff());
    }

    match /institutions/{institutionId}/courses/{courseId} {
      allow read: if canReadInstitutionDepartment(institutionId, resource.data.departmentId);
      allow write: if isAuthenticated() && institutionMatch(institutionId) && (isInstitutionAdmin() || isStaff());
    }

    match /institutions/{institutionId}/analytics/{docId} {
      allow read: if isAuthenticated() && institutionMatch(institutionId) && (isInstitutionAdmin() || isStaff());
      allow write: if false; // backend-only
    }

    match /institutions/{institutionId}/libraryItems/{itemId} {
      allow read: if canReadInstitutionDepartment(institutionId, resource.data.departmentId);
      allow write: if false; // backend-only for now
    }

    match /institutions/{institutionId}/announcements/{announcementId} {
      allow read: if canReadInstitutionDepartment(institutionId, resource.data.departmentId);
      allow write: if isAuthenticated() && institutionMatch(institutionId) && (isInstitutionAdmin() || isStaff());
    }

    match /institutions/{institutionId}/audits/{auditId} {
      allow read: if isAuthenticated() && institutionMatch(institutionId) && (isInstitutionAdmin() || isStaff());
      allow write: if false; // backend-only
    }

    match /institutions/{institutionId}/reports/{departmentId}/weekly/{weekKey} {
      allow read: if canReadInstitutionDepartment(institutionId, departmentId);
      allow write: if false; // backend-only
    }

    match /institutions/{institutionId}/assignments/{assignmentId} {
      allow read: if canReadInstitutionDepartment(institutionId, resource.data.departmentId);
      allow create, update: if isAuthenticated()
        && institutionMatch(institutionId)
        && (isInstitutionAdmin() || (isStaff() && departmentMatch(request.resource.data.departmentId)));
      allow delete: if isAuthenticated()
        && institutionMatch(institutionId)
        && (isInstitutionAdmin() || (isStaff() && departmentMatch(resource.data.departmentId)));
    }

    match /institutions/{institutionId}/notes/{noteId} {
      allow read: if isAuthenticated()
        && institutionMatch(institutionId)
        && request.auth.uid == resource.data.ownerUid;
      allow create, update: if isAuthenticated()
        && institutionMatch(institutionId)
        && request.auth.uid == request.resource.data.ownerUid;
      allow delete: if isAuthenticated()
        && institutionMatch(institutionId)
        && request.auth.uid == resource.data.ownerUid;
    }

    match /institutions/{institutionId}/cases/{caseId} {
      allow read: if isAuthenticated()
        && institutionMatch(institutionId)
        && (
          isInstitutionAdmin()
          || (isStaff() && departmentMatch(resource.data.departmentId))
          || (isStudentRole() && request.auth.uid == resource.data.studentId)
        );
      allow create: if isAuthenticated()
        && institutionMatch(institutionId)
        && (
          isInstitutionAdmin()
          || (isStaff() && departmentMatch(request.resource.data.departmentId))
          || (isStudentRole() && request.auth.uid == request.resource.data.studentId)
        );
      allow update: if isAuthenticated()
        && institutionMatch(institutionId)
        && (
          isInstitutionAdmin()
          || (isStaff() && departmentMatch(resource.data.departmentId) && departmentMatch(request.resource.data.departmentId))
          || (isStudentRole()
            && request.auth.uid == resource.data.studentId
            && request.auth.uid == request.resource.data.studentId
            && resource.data.departmentId == request.resource.data.departmentId)
        );
      allow delete: if false;
    }

    match /institutions/{institutionId}/cases/{caseId}/messages/{messageId} {
      function parentCase() {
        return get(/databases/$(database)/documents/institutions/$(institutionId)/cases/$(caseId)).data;
      }

      allow read: if isAuthenticated()
        && institutionMatch(institutionId)
        && (
          isInstitutionAdmin()
          || (isStaff() && departmentMatch(parentCase().departmentId) && departmentMatch(resource.data.departmentId))
          || (isStudentRole() && request.auth.uid == parentCase().studentId && resource.data.departmentId == parentCase().departmentId)
        );

      allow create: if isAuthenticated()
        && institutionMatch(institutionId)
        && (
          isInstitutionAdmin()
          || (isStaff() && departmentMatch(parentCase().departmentId) && departmentMatch(request.resource.data.departmentId))
          || (isStudentRole() && request.auth.uid == parentCase().studentId)
        );

      allow update, delete: if false;
    }

    match /public/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Index suggestions (if queries require them):
// 1) institutions/{institutionId}/cases: departmentId ASC, lastUpdated DESC
// 2) institutions/{institutionId}/assignments: departmentId ASC, createdAt DESC
// 3) institutions/{institutionId}/libraryItems: departmentId ASC, updatedAt DESC
